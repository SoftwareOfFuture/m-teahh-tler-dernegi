# Canlı site adresi (canonical, Open Graph, sitemap). Örn: https://www.antmutder.org
NEXT_PUBLIC_SITE_URL=https://www.antmutder.org

# Görsel yükleme: Admin panelde "Yerelden görsel yükle" backend üzerinden Cloudinary kullanır.
# Backend .env içinde CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET tanımlayın.

# Eski / opsiyonel: EmailJS (Contact form + Forgot password) - https://www.emailjs.com/
# VITE_EMAILJS_SERVICE_ID=your_service_id
# VITE_EMAILJS_TEMPLATE_ID=your_template_id
# VITE_EMAILJS_TEMPLATE_ID_RESET=your_reset_template_id
# VITE_EMAILJS_PUBLIC_KEY=your_public_key
